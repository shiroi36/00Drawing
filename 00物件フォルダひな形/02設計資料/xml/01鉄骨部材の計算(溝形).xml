<?xml version="1.0" encoding="UTF-8"?>

<root>

    <!-- ファイル名=%小梁計算%.xmlとすると、自動的にプログラムが読み込んで計算することとしました。 -->
    <!--数字の入力はexp4jでの入力形式ですので、ある程度の計算式は可能です-->
    <!--https://mvnrepository.com/artifact/net.objecthunter/exp4j/0.4.8-->
    <!--https://salumarine.com/how-to-evaluate-mathematical-expression-string-in-java/-->

    <!--ここから屋根鉄骨梁・間柱・耐風梁の計算設定-->
    <calcs>


        <calc>

            <beam sec="m15" l="7500" mat="ss400forshort">
                荷重入力のサンプルファイル
            </beam>

            <isfbdegration>false</isfbdegration>
            <axialforce>30000</axialforce>


            <pointload isstrong="true" pl="3500"      p="2.5*1.9*1000"        >nizuri</pointload>
            <taper     isstrong="true" sl="0"        tl="0"  wl="7650" w="0.6">nizuri</taper>
            <interval  isstrong="true" w="3.1*4.0" bnum="2"                   >1fwind</interval>
            <uniform   isstrong="true" w="4.0"                                >nizuri</uniform>

            <gusset gsec="none" gmat="ss400forshort" glg="2700">h250t12f10tm20</gusset>

        </calc>



        <calc>

            <beam sec="m390" l="9999" mat="ss400forshort">
                1本吊りのサンプル L=9999mm 支配幅4.44m
            </beam>
            <isfbdegration>false</isfbdegration>
            <axialforce>0</axialforce>

            <uniform   isstrong="false" w="4.44"                                    >wall</uniform>
            <pointload isstrong="false" pl="9999*1/2" p="-1.25*9999/2000*4.44*1000" >wall</pointload>

            <gusset gsec="none" gmat="ss400forshort" glg="2700">h250t12f10tm20</gusset>

        </calc>



        <calc>

            <beam sec="m390" l="9999" mat="ss400forshort">
               2本吊りのサンプル L=9999mm 支配幅4.44m
            </beam>
            <isfbdegration>false</isfbdegration>
            <axialforce>0</axialforce>

            <uniform   isstrong="false" w="4.44"                                     >wall</uniform>
            <pointload isstrong="false" pl="9999*1/3" p="-1.0995*9999/3000*4.44*1000">wall</pointload>
            <pointload isstrong="false" pl="9999*2/3" p="-1.0995*9999/3000*4.44*1000">wall</pointload>

            <gusset gsec="none" gmat="ss400forshort" glg="2700">h250t12f10tm20</gusset>

        </calc>



        

        <calc>

            <beam sec="m390" l="9999" mat="ss400forshort">
                3本吊りのサンプル L=9999mm 支配幅4.44m
            </beam>
            <isfbdegration>false</isfbdegration>
           <axialforce>0</axialforce>

            <uniform   isstrong="false" w="4.4"                                       >wall</uniform>
            <pointload isstrong="false" pl="9999*1/4" p="-1.14285*9999/4000*4.4*1000" >wall</pointload>
            <pointload isstrong="false" pl="9999*2/4" p="-0.92858*9999/4000*4.4*1000" >wall</pointload>
            <pointload isstrong="false" pl="9999*3/4" p="-1.14285*9999/4000*4.4*1000" >wall</pointload>

            <gusset gsec="none" gmat="ss400forshort" glg="2700">h250t12f10tm20</gusset>

        </calc>
    </calcs>

    <!--各計算時の荷重の設定情報です。-->
    <!-- このタグは<uniform><interval><pointload><taper>のtextcontentを参照する関係となります。
    指定する荷重値は固定とか積載とかではなく、単なる荷重値となります。 -->
    <loads>

        <!--駐車場の小梁
        kN/m2-->
        <!-- valueには床荷重kN/m2を入力してください。 -->
        <load value="1.6" name="屋根小梁">roof</load>
        <load value="0.8" name="壁荷重">wall</load>
        <load value="2.5" name="荷摺り荷重">nizuri</load>
        <load value="0.8" name="屋根大梁">yanekohari</load>
        <load value="1.3" name="1F風荷重">1fwind</load>
        <load value="1.5" name="2F風荷重">2fwind</load>
        <load value="1.3+2.95+0.4+2.75" name="店舗小梁">storebeam</load>

        <!--以下はXML入力上必要な荷重設定です。-->
        <load value="1.0" name="単位荷重">unit</load><!--全て倍率を一倍-->

    </loads>

    <!--材料の設定情報です。材料の設定を切り替えることにより、長短期の検討を分けます-->
    <materials>
        <!--材料だけど2通りしかないのでとりあえず以下のみでOKかな-->
        <!-- SS400で長期の検討をしたい場合 -->
        <material>ss400forsustained</material>
        <!-- ss400で短期の検討をしたい場合 -->
        <material>ss400forshort</material>
        <!-- SM490で長期の検討をしたい場合 -->
        <material>sm490forsustained</material>
        <!-- SM490で短期の検討をしたい場合 -->
        <material>sm490forshort</material>
    </materials>

    <bolts>
        <!--材料だけど2通りしかないのでとりあえず以下のみでOKかな-->
        <bolt type="f8t" d="16">f8tm16</bolt>
        <bolt type="f8t" d="20">f8tm20</bolt>
        <bolt type="f8t" d="22">f8tm22</bolt>
        <bolt type="f8t" d="24">f8tm24</bolt>
        <bolt type="f10t" d="16">f10tm16</bolt>
        <bolt type="f10t" d="20">f10tm20</bolt>
        <bolt type="f10t" d="22">f10tm22</bolt>
        <bolt type="f10t" d="24">f10tm24</bolt>
        <bolt type="shtb" d="16">shtbm16</bolt>
        <bolt type="shtb" d="20">shtbm20</bolt>
        <bolt type="shtb" d="22">shtbm22</bolt>
        <bolt type="shtb" d="24">shtbm24</bolt>
        <bolt type="12g" d="16">12gm16</bolt>
        <bolt type="12g" d="20">12gm20</bolt>
        <bolt type="12g" d="22">12gm22</bolt>
        <bolt type="12g" d="24">12gm24</bolt>
    </bolts>
    

    <gussets>
        <gusset m="2" n="2" p="60" t="12" bolt="f10tm20">h250t12f10tm20</gusset>
        <gusset m="2" n="1" p="60" t="6" bolt="f10tm20">h250t6f10tm20</gusset>
        <gusset m="2" n="1" p="60" t="9" bolt="f10tm16">h250t9f10tm16</gusset>
        <gusset m="4" n="1" p="60" t="9" bolt="f10tm20">h400t9f10tm20</gusset>
        <gusset m="4" n="1" p="90" t="9" bolt="f10tm20">h450t9f10tm20</gusset>
        <gusset m="4" n="1" p="90" t="9" bolt="f10tm20">h500t9f10tm20</gusset>
        <gusset m="6" n="1" p="60" t="12" bolt="f10tm22">h500t12f10tm22</gusset>
        <gusset m="5" n="1" p="90" t="12" bolt="f10tm22">h600t12f10tm22</gusset>
        <gusset m="8" n="1" p="60" t="16" bolt="f10tm22">h700t16f10tm22</gusset>
        <gusset m="12" n="1" p="60" t="16" bolt="f10tm22">h900t16f10tm22</gusset>
    </gussets>

    <!--梁の設定情報-->
    <sections>
        <section size="manual" name="c-75x40x5x7" fbdeg="1" A="8.818*100" Ix="75.3*10000" Iy="12.2*10000" Zx="20.1*1000" Zy="4.47*1000" ib="1.12*10">c-75x40x5x7</section>
        <section size="manual" name="c-100x50x5x7.5" fbdeg="1" A="11.92*100" Ix="210*10000" Iy="18.8*10000" Zx="42.1*1000" Zy="5.59*1000" ib="1.26*10">c-100x50x5x7.5</section>
        <section size="manual" name="c-125x65x6x9" fbdeg="1" A="17.11*100" Ix="424*10000" Iy="61.8*10000" Zx="67.8*1000" Zy="13.4*1000" ib="1.9*10">c-125x65x6x9</section>
        <section size="manual" name="c-150x75x6.5x10" fbdeg="1" A="23.71*100" Ix="861*10000" Iy="117*10000" Zx="115*1000" Zy="22.4*1000" ib="2.22*10">c-150x75x6.5x10</section>
        <section size="manual" name="c-150x75x9x12.5" fbdeg="1" A="30.59*100" Ix="1050*10000" Iy="147*10000" Zx="140*1000" Zy="28.3*1000" ib="2.19*10">c-150x75x9x12.5</section>
        <section size="manual" name="c-180x75x7x10.5" fbdeg="1" A="27.2*100" Ix="1380*10000" Iy="131*10000" Zx="153*1000" Zy="24.3*1000" ib="2.18*10">c-180x75x7x10.5</section>
        <section size="manual" name="c-200x80x7.5x11" fbdeg="1" A="31.39*100" Ix="1950*10000" Iy="168*10000" Zx="195*1000" Zy="29.1*1000" ib="2.3*10">c-200x80x7.5x11</section>
        <section size="manual" name="c-200x90x8x13.5" fbdeg="1" A="38.65*100" Ix="2490*10000" Iy="277*10000" Zx="249*1000" Zy="44.2*1000" ib="2.68*10">c-200x90x8x13.5</section>
        <section size="manual" name="c-250x90x9x13" fbdeg="1" A="44.07*100" Ix="4180*10000" Iy="294*10000" Zx="334*1000" Zy="44.5*1000" ib="2.58*10">c-250x90x9x13</section>
        <section size="manual" name="c-300x90x9x13" fbdeg="1" A="48.57*100" Ix="6440*10000" Iy="309*10000" Zx="429*1000" Zy="45.7*1000" ib="2.52*10">c-300x90x9x13</section>

        <!--以下のようにエックスX：X-Ray
        で区切って断面入力します。一応h-のprefixをつけました-->
        <!--細幅シリーズなのでprifixにnつけました-->
        <!-- <section size="h-198x99x4.5x7x8">n19</section> -->
        
    </sections>

</root>
